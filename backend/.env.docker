APP_NAME="Attendance System"
API_V1_PREFIX="/api/v1"
CORS_ORIGINS='["http://localhost:3000"]'

DATABASE_URL="postgresql+psycopg://attendance:attendance@db:5432/attendance"
REDIS_URL="redis://redis:6379/0"
SQLALCHEMY_ECHO="false"

# These are relative to WORKDIR=/app inside the container
DATA_DIR="./data"
MODEL_DIR="./models"
UPLOAD_DIR="./data/imports"
IMPORTS_REVALIDATE_FAILED_ON_REUPLOAD="true"

# Dev-only admin mode
# - Enables admin-only endpoints in the API (e.g. mobile account provisioning/revoke).
# - This is NOT production auth; lock it down before real deployments.
ADMIN_MODE="true"
MOBILE_MAPPING_DRY_RUN="false"

# Firebase credentials for mobile sync
FIREBASE_SERVICE_ACCOUNT_PATH="/app/secrets/firebase-service-account.json"

# Phase 3 mobile sync (Firestore namespace v1)
MOBILE_SYNC_ENABLED="true"
MOBILE_SYNC_DRY_RUN="false"
MOBILE_SYNC_ADMIN_ENABLED="false"
# MOBILE_SYNC_ADMIN_TOKEN="dev-token"

# HR module (Phase 4): Gemini explanations
# NOTE: Keep this empty in source control; set it in your shell or a private env file.
GEMINI_API_KEY="AIzaSyBiRCV0u2X2qwe8Gn7kcDV2eue8SlgDEBk"
GEMINI_MODEL="gemini-2.5-flash-lite"
GEMINI_TIMEOUT_SEC="60"
GEMINI_MAX_TOP_N="20"

YOLO_MODEL_PATH="./models/yolo/yolo11n.pt"
INSIGHTFACE_ROOT="./models/insightface"
FACEDET_MODEL_PATH="./models/frigate/facedet.onnx"
LANDMARK_MODEL_PATH="./models/frigate/landmarkdet.yaml"
ARCFACE_MODEL_PATH="./models/frigate/arcface.onnx"

# Face system tuning (your current debug-friendly values)
MIN_FACES=3
RECOGNITION_THRESHOLD=0.55
UNKNOWN_SCORE=0.40
FACE_MIN_AREA=250
SAVE_ATTEMPTS=true
EXPAND_UPWARD_FRAC=0.60

#   SAVE_LAST_SEEN_SNAPSHOTS=true|false
#   LAST_SEEN_SNAPSHOT_INTERVAL_SEC=2.0
#   ATTACH_LAST_SEEN_SNAPSHOT_TO_INFERRED_EXIT=true|false
