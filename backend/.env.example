APP_NAME="Attendance System"
API_V1_PREFIX="/api/v1"
CORS_ORIGINS='["http://localhost:3000"]'

# Local dev (adjust host/port for Docker vs local Postgres)
DATABASE_URL="postgresql+psycopg://attendance:attendance@localhost:5432/attendance"
REDIS_URL="redis://localhost:6379/0"
SQLALCHEMY_ECHO="false"

# Data directories (repo-relative by default)
DATA_DIR="./data"
UPLOAD_DIR="./data/imports"
# If a dataset import FAILED, allow re-uploading the same file (same checksum)
# to re-validate using the current parser code.
IMPORTS_REVALIDATE_FAILED_ON_REUPLOAD="true"
MODEL_DIR="./models"

# HR module (Phase 1/2)
# - Resumes are stored under: <DATA_DIR>/hr/resumes/...
# - Embeddings are stored in Postgres (pgvector) and the model is cached under HR_EMBED_CACHE_DIR.
HR_EMBEDDINGS_ENABLED="true"
HR_EMBED_MODEL_NAME="BAAI/bge-m3"
HR_EMBED_DIM="1024"
HR_EMBED_CACHE_DIR="./models/text_embeddings"
HR_EMBED_DEVICE="cpu"
HR_EMBED_MAX_SEQ_LENGTH="8192"
HR_EMBED_MAX_CHARS="12000"
HR_VIEW_MIN_CHARS="120"
# Debug-only semantic search endpoint for HR (disable in most environments).
HR_SEARCH_DEBUG_ENABLED="false"

# HR module (Phase 3): ScreeningRun (retrieve + rerank)
HR_RERANK_ENABLED="true"
HR_RERANKER_MODEL_NAME="BAAI/bge-reranker-v2-m3"
HR_RERANKER_BATCH_SIZE="32"
HR_RERANKER_MAX_CHARS="12000"
HR_SCREENING_DEFAULT_VIEW_TYPES='["skills","experience","full"]'
HR_SCREENING_DEFAULT_K_PER_VIEW="200"
HR_SCREENING_DEFAULT_POOL_SIZE="400"
HR_SCREENING_DEFAULT_TOP_N="200"
HR_SCREENING_JOB_TIMEOUT_SEC="3600"
HR_SCREENING_PROGRESS_UPDATE_EVERY="10"

# HR module (Phase 4): Gemini explanations (post-ranking, async)
# - If GEMINI_API_KEY is empty/missing, the system will skip auto explanations.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash-lite-001"
GEMINI_TIMEOUT_SEC="60"
GEMINI_MAX_TOP_N="20"

# YOLO + tracking
YOLO_MODEL_PATH="./models/yolo/yolo11n.pt"
YOLO_TRACKER="bytetrack.yaml"

# Face system models (local/offline)
FACEDET_MODEL_PATH="./models/face_det/face_detection_yunet_2023mar.onnx"
LANDMARK_MODEL_PATH="./data/models/facedet/landmarkdet.yaml"
ARCFACE_MODEL_PATH="./models/insightface/models/buffalo_l/w600k_r50.onnx"

# Firebase credentials for mobile sync
# FIREBASE_SERVICE_ACCOUNT_PATH="/app/secrets/firebase-service-account.json"
#
# Alternatively provide service account JSON as base64 (recommended for Docker/env files):
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64="base64-encoded-json"
# (Legacy alias still supported)
# FIREBASE_SERVICE_ACCOUNT_JSON="base64-encoded-json"
# FIREBASE_PROJECT_ID="your-project-id"

# Phase 3: mobile sync (Firestore namespace v1)
MOBILE_SYNC_ENABLED="false"
MOBILE_SYNC_DRY_RUN="false"
MOBILE_SYNC_ADMIN_ENABLED="false"
# MOBILE_SYNC_ADMIN_TOKEN="dev-token"

# Mobile login bootstrap mapping (users/{uid})
ADMIN_MODE="false"
MOBILE_MAPPING_DRY_RUN="false"
